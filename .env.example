# ========== Chat 模型配置（必填）==========
# 用于生成回答的对话模型
CHAT_API_KEY=sk-your-chat-api-key-here
CHAT_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
# API 模式: completions（标准 /v1/chat/completions）或 responses（新版 /v1/responses）
CHAT_API_MODE=completions

# ========== Embedding 模型配置（必填）==========
# 用于文本向量化的 Embedding 模型（可与 Chat 使用不同服务商）
EMBEDDING_API_KEY=sk-your-embedding-api-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Milvus 连接配置（默认本地 Docker）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=crm_knowledge_base
